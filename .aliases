#!/usr/bin/bash

# Aliases

## General

alias update='sudo apt update -y'
alias upgrade='sudo apt upgrade -y'
alias clean-upgrade="update --refresh && upgrade && sudo dnf clean all && sudo dnf autoremove"
alias sudo='sudo '
alias c='clear'
alias ipconfig='ifconfig'
alias vi='vim'

## OS package managers

if [ -f /etc/debian_version ]; then
  alias yum='apt'
  alias dnf='yum'
elif [ -f /etc/redhat-release ]; then
  alias yum='dnf'
  alias apt='yum'
  alias apt-get='yum'
elif [ -f /etc/arch-release ]; then
  alias yum='pacman'
  alias apt='yum'
  alias dnf='apt'
  alias apt-get='yum'
  alias update='sudo pacman -Syu'
fi

## direnv

if command -v direnv &> /dev/null; then
    if [ -n "$ZSH_VERSION" ]; then
        eval "$(direnv hook zsh)"
    elif [ -n "$BASH_VERSION" ]; then
        eval "$(direnv hook bash)"
    fi
fi

## Git

alias git-remove-untracked='git fetch --prune && git branch -r | awk "{print \$1}" | egrep -v -f /dev/fd/0 <(git branch -vv | grep origin) | awk "{print \$1}" | xargs git branch -d'

## LS

alias lt='ls --human-readable --size -1 -S --classify'
alias lda='ls -al --color | sort -k1 -h'
alias ld='ls --color | sort -k1'

## Docker / Podman

# Prefer podman when present; only fall back to real docker if it's missing.
if command -v podman &> /dev/null; then
    export DOCKER_HOST="unix:///var/run/podman/podman.sock"
    export PODMAN_COMPOSE_WARNING_LOGS=false
    alias docker=podman
elif command -v docker &> /dev/null; then
    export DOCKER_HOST="unix:///var/run/docker.sock"
fi

alias dk='docker'
alias 'docker-compose'='docker compose'
alias dkc='docker-compose'
alias dkup='dkc up'
alias dkdn='dkc down'

## Python

python() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" "$@"
    else
        /usr/bin/python3.12 "$@"
    fi
}

python3() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" "$@"
    else
        /usr/bin/python3
    fi
}

py() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" "$@"
    else
        /usr/bin/python3.12 "$@"
    fi
}

pip() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" -m pip "$@"
    else
        /usr/bin/python3.12 -m pip "$@"
    fi
}

pip3() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" -m pip "$@"
    else
        /usr/bin/python3.12 -m pip "$@"
    fi
}

## Requires other dependecies
alias dkps='docker run --rm -it -v /var/run/docker.sock:/var/run/docker.sock -v ~/git/Self-Host/lazydocker/config:/.config/jesseduffield/lazydocker lazyteam/lazydocker'
