#!/usr/bin/bash

# Aliases

## General

alias update='sudo apt update -y'
alias upgrade='sudo apt upgrade -y'
alias clean-upgrade="update --refresh && upgrade && sudo dnf clean all && sudo dnf autoremove"
alias sudo='sudo '
alias c='clear'
alias ipconfig='ifconfig'

## OS package managers

if [ -f /etc/debian_version ]; then
  alias yum='apt'
  alias dnf='yum'
elif [ -f /etc/redhat-release ]; then
  alias yum='dnf'
  alias apt='yum'
  alias apt-get='yum'
elif [ -f /etc/arch-release ]; then
  alias yum='pacman'
  alias apt='yum'
  alias dnf='apt'
  alias apt-get='yum'
  alias update='sudo pacman -Syu'
fi

## direnv

if command -v direnv &> /dev/null; then
    if [ -n "$ZSH_VERSION" ]; then
        eval "$(direnv hook zsh)"
    elif [ -n "$BASH_VERSION" ]; then
        eval "$(direnv hook bash)"
    fi
fi

## NVM

export NVM_DIR="$HOME/.config/nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

## Editor

# Prefer nvim locally, vim over SSH; fall back through vi/nano for
# minimal systems that don't have vim installed at all.
if [ -n "$SSH_CONNECTION" ]; then
    _editor_candidates=(vim vi nano)
else
    _editor_candidates=(nvim vim vi nano)
fi

for _editor in "${_editor_candidates[@]}"; do
    if command -v "$_editor" &> /dev/null; then
        export EDITOR="$_editor"
        break
    fi
done
unset _editor_candidates _editor

alias vi="$EDITOR"
alias vim="$EDITOR"

## Git

alias git-remove-untracked='git fetch --prune && git branch -r | awk "{print \$1}" | egrep -v -f /dev/fd/0 <(git branch -vv | grep origin) | awk "{print \$1}" | xargs git branch -d'

## LS

alias lt='ls --human-readable --size -1 -S --classify'
alias lda='ls -al --color | sort -k1 -h'
alias ld='ls --color | sort -k1'

## Docker / Podman

# Prefer docker when present; only check for podman as a fallback.
if command -v docker &> /dev/null; then
    export DOCKER_HOST="unix:///var/run/docker.sock"
elif command -v podman &> /dev/null; then
    # Rootless podman (the common default on RHEL/Rocky and elsewhere) uses a
    # per-user socket; fall back to the rootful system socket if that's not
    # what's running.
    _podman_rootless_sock="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/podman/podman.sock"
    if [ -S "$_podman_rootless_sock" ]; then
        export DOCKER_HOST="unix://${_podman_rootless_sock}"
    else
        export DOCKER_HOST="unix:///var/run/podman/podman.sock"
    fi
    unset _podman_rootless_sock
    export PODMAN_COMPOSE_WARNING_LOGS=false
    alias docker=podman
fi

alias dk='docker'
alias 'docker-compose'='docker compose'
alias dkc='docker-compose'
alias dkup='dkc up'
alias dkdn='dkc down'

## Python

# oh-my-zsh's python plugin conditionally sets `alias py='python3'`; unalias
# first so defining these as functions doesn't trigger zsh's "overriding
# another alias" warning. See .claude/CLAUDE.md for why the plugin is kept.
unalias python python3 py pip pip3 2>/dev/null

python() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" "$@"
    else
        command python3 "$@"
    fi
}

python3() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" "$@"
    else
        command python3 "$@"
    fi
}

py() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" "$@"
    else
        command python3 "$@"
    fi
}

pip() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" -m pip "$@"
    else
        command python3 -m pip "$@"
    fi
}

pip3() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        "$VIRTUAL_ENV/bin/python" -m pip "$@"
    else
        command python3 -m pip "$@"
    fi
}

## Requires other dependecies
alias dkps='docker run --rm -it -v /var/run/docker.sock:/var/run/docker.sock -v ~/git/Self-Host/lazydocker/config:/.config/jesseduffield/lazydocker lazyteam/lazydocker'
